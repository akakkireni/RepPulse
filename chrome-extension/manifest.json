{
  "manifest_version": 3,
  "name": "Rep Pulse",
  "version": "1.0.0",
  "description": "Records API network calls on the configured host (see config.js). Uses chrome.webRequest. Data stays on this device until exported.",
  "permissions": ["webRequest", "storage", "tabs"],
  "host_permissions": ["https://*.reputation.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rep Pulse",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
